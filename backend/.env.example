# JavBus
JAVBUS_BASE_URL=https://www.javbus.com
JAVBUS_LANG=zh

# PikPak
PIKPAK_USERNAME=
PIKPAK_PASSWORD=
PIKPAK_DOWNLOAD_FOLDER=AVBT

# 自動歸檔：完成的離線任務搬到此資料夾下對應番號的子目錄
ARCHIVE_ENABLED=true
PIKPAK_ARCHIVE_FOLDER=AVBT/已完成
ARCHIVE_INTERVAL_SECONDS=60

# 可選：代理（格式 http://host:port 或 socks5://host:port）
HTTP_PROXY=

# 資料庫檔案路徑（相對於 backend 目錄）
DATABASE_URL=sqlite+aiosqlite:///./data/avbt.db
