# JavBus
JAVBUS_BASE_URL=https://www.javbus.com
JAVBUS_LANG=zh

# PikPak
PIKPAK_USERNAME=
PIKPAK_PASSWORD=
PIKPAK_DOWNLOAD_FOLDER=AVBT

# pCloud（可選）— 用於 /pcloud 雲端檔案管理頁。
# 帳號在哪個資料中心會自動偵測（US api.pcloud.com / EU eapi.pcloud.com）。
PCLOUD_USERNAME=
PCLOUD_PASSWORD=

# 自動歸檔：完成的離線任務搬到此資料夾下對應番號的子目錄
ARCHIVE_ENABLED=true
PIKPAK_ARCHIVE_FOLDER=AVBT/已完成
ARCHIVE_INTERVAL_SECONDS=60

# 階層式歸檔：每個追蹤分類在 PikPak 的完整路徑（不含 name 與番號）。
# 留空時用 <PIKPAK_DOWNLOAD_FOLDER>/<kind>，例如 AVBT/series。
# 若你的 PikPak 結構是中文或多層巢狀，請手動指定，例如：
#   PIKPAK_SERIES_FOLDER=AVBT/AVBT/系列/系列
#   PIKPAK_STAR_FOLDER=AVBT/AVBT/女優/女優
PIKPAK_SERIES_FOLDER=
PIKPAK_STAR_FOLDER=
PIKPAK_STUDIO_FOLDER=
PIKPAK_LABEL_FOLDER=
PIKPAK_DIRECTOR_FOLDER=

# 女優追蹤：每 N 秒掃 TrackedListing 看有沒有新作品
TRACKER_ENABLED=true
TRACKER_INTERVAL_SECONDS=3600
TRACKER_AUTO_SEND_HD_ONLY=true
TRACKER_AUTO_SEND_SKIP_SENT=true

# 可選：代理（格式 http://host:port 或 socks5://host:port）
HTTP_PROXY=

# 可選：歸檔完成時 POST {"content": "..."} 到此 URL（Discord webhook 格式）
WEBHOOK_URL=

# ---- Telegram 通知(可選)----
# 設定後,追蹤新作/歸檔完成等事件會同時推播到 Telegram。
# Bot token 向 @BotFather 申請;chat id 可用 @userinfobot 查詢。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 各事件預設開關(可在「設定」頁調整,頁面設定優先於此處)
NOTIFY_TRACKED_NEW=true
NOTIFY_ARCHIVE_DONE=true
NOTIFY_ARCHIVE_FAILED=true
NOTIFY_DOWNLOAD_FAILED=false
NOTIFY_SCRAPER_ALERT=true

# 允許的前端來源(CORS),逗號分隔;含 * 時全開(此時瀏覽器規範強制不帶憑證)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 圖片代理額外允許的域名後綴(逗號分隔,附加在內建 JavBus CDN 清單之後)
# 例:IMG_PROXY_ALLOWED_HOSTS=.example-cdn.com,img.other.net
IMG_PROXY_ALLOWED_HOSTS=

# ---- 自動資料庫備份 ----
# 每 N 小時把 SQLite 複製到 data/backups/,保留最新 KEEP 份
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_HOURS=24
AUTO_BACKUP_KEEP=7

# ---- 登入門禁 ----
# 本站採單一帳號門禁：首次開站時於前端 /setup 設定管理員帳密（雜湊後存進 DB），
# 之後可在「設定」頁修改密碼。除影像代理與健康檢查外，所有 API 都需登入。
# AUTH_SECRET：簽 JWT 的密鑰。留空時啟動會自動產生並寫入 data/auth_secret.txt，
#              token 重啟後仍有效；多台部署共用同一把密鑰時可在此明確指定。
AUTH_SECRET=
# 登入 token 的有效期（小時）。預設 720 = 30 天。
AUTH_TOKEN_TTL_HOURS=720

# 資料庫檔案路徑（相對於 backend 目錄）
DATABASE_URL=sqlite+aiosqlite:///./data/avbt.db

# ---- pCloud（PikPak → pCloud 遠端傳輸）----
# 帳密 或 access token 任一即可,token 優先;沒填的話可在 /pcloud 頁面登入
PCLOUD_USERNAME=
PCLOUD_PASSWORD=
PCLOUD_ACCESS_TOKEN=
# us / eu / auto (auto 先試 us,失敗 fallback eu,結果寫到 data/pcloud_region.txt)
PCLOUD_REGION=auto
# 預設要把檔案存到 pCloud 的哪個目錄(若不存在會自動建立)
PCLOUD_DEFAULT_FOLDER=/From PikPak
# 同時併發送出幾個 savefilefromurl 請求
PCLOUD_TRANSFER_CONCURRENCY=3
# 輪詢上傳進度的間隔(秒)
PCLOUD_POLL_INTERVAL_SECONDS=15

# 日誌等級(DEBUG/INFO/WARNING/ERROR;預設 INFO)
LOG_LEVEL=INFO
