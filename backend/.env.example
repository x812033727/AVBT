# JavBus
JAVBUS_BASE_URL=https://www.javbus.com
JAVBUS_LANG=zh

# PikPak
PIKPAK_USERNAME=
PIKPAK_PASSWORD=
PIKPAK_DOWNLOAD_FOLDER=AVBT

# 自動歸檔：完成的離線任務搬到此資料夾下對應番號的子目錄
ARCHIVE_ENABLED=true
PIKPAK_ARCHIVE_FOLDER=AVBT/已完成
ARCHIVE_INTERVAL_SECONDS=60

# 階層式歸檔：每個追蹤分類在 PikPak 的完整路徑（不含 name 與番號）。
# 留空時用 <PIKPAK_DOWNLOAD_FOLDER>/<kind>，例如 AVBT/series。
# 若你的 PikPak 結構是中文或多層巢狀，請手動指定，例如：
#   PIKPAK_SERIES_FOLDER=AVBT/AVBT/系列/系列
#   PIKPAK_STAR_FOLDER=AVBT/AVBT/女優/女優
PIKPAK_SERIES_FOLDER=
PIKPAK_STAR_FOLDER=
PIKPAK_STUDIO_FOLDER=
PIKPAK_LABEL_FOLDER=
PIKPAK_DIRECTOR_FOLDER=

# 女優追蹤：每 N 秒掃 TrackedActress 看有沒有新作品
TRACKER_ENABLED=true
TRACKER_INTERVAL_SECONDS=3600
TRACKER_AUTO_SEND_HD_ONLY=true
TRACKER_AUTO_SEND_SKIP_SENT=true

# 可選：代理（格式 http://host:port 或 socks5://host:port）
HTTP_PROXY=

# 可選：歸檔完成時 POST {"content": "..."} 到此 URL（Discord webhook 格式）
WEBHOOK_URL=

# 資料庫檔案路徑（相對於 backend 目錄）
DATABASE_URL=sqlite+aiosqlite:///./data/avbt.db

# ---- pCloud（PikPak → pCloud 遠端傳輸）----
# 帳密 或 access token 任一即可,token 優先;沒填的話可在 /pcloud 頁面登入
PCLOUD_USERNAME=
PCLOUD_PASSWORD=
PCLOUD_ACCESS_TOKEN=
# us / eu / auto (auto 先試 us,失敗 fallback eu,結果寫到 data/pcloud_region.txt)
PCLOUD_REGION=auto
# 預設要把檔案存到 pCloud 的哪個目錄(若不存在會自動建立)
PCLOUD_DEFAULT_FOLDER=/From PikPak
# 同時併發送出幾個 savefilefromurl 請求
PCLOUD_TRANSFER_CONCURRENCY=3
# 輪詢上傳進度的間隔(秒)
PCLOUD_POLL_INTERVAL_SECONDS=15
